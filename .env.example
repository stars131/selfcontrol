POSTGRES_DB=selfcontrol
POSTGRES_USER=selfcontrol
POSTGRES_PASSWORD=selfcontrol
DATABASE_URL=postgresql+psycopg://selfcontrol:selfcontrol@db:5432/selfcontrol
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=10080
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
AUTO_CREATE_TABLES=true
STORAGE_DIR=./storage/uploads
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=hash-embedding-v1
EMBEDDING_DIMENSIONS=256
RAG_CHUNK_SIZE_CHARS=700
RAG_CHUNK_OVERLAP_CHARS=120
RAG_SEARCH_LIMIT=8
PROCESSING_TMP_DIR=./storage/tmp
PROVIDER_REQUEST_TIMEOUT_SECONDS=90
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AMAP_KEY=your-amap-web-js-key
