POSTGRES_DB=selfcontrol
POSTGRES_USER=selfcontrol
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql+psycopg://selfcontrol:change-this-db-password@db:5432/selfcontrol
REDIS_URL=redis://redis:6379/0
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=10080
APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
AUTO_CREATE_TABLES=false
STORAGE_DIR=./storage/uploads
MEDIA_PROCESSING_MODE=async
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=hash-embedding-v1
EMBEDDING_DIMENSIONS=256
RAG_CHUNK_SIZE_CHARS=700
RAG_CHUNK_OVERLAP_CHARS=120
RAG_SEARCH_LIMIT=8
PROCESSING_TMP_DIR=./storage/tmp
PROVIDER_REQUEST_TIMEOUT_SECONDS=90
REMOTE_MEDIA_RETRY_MAX_ATTEMPTS=3
REMOTE_MEDIA_RETRY_BACKOFF_SECONDS=60,300,900
CORS_ORIGINS=http://your-domain.example
ALLOWED_HOSTS=your-domain.example
FORWARDED_ALLOW_IPS=*
DOMAIN_NAME=your-domain.example
CERTBOT_EMAIL=admin@your-domain.example
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_API_BASE_URL=http://your-domain.example/api/v1
NEXT_PUBLIC_AMAP_KEY=your-amap-web-js-key
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
TMP_RETENTION_DAYS=3
